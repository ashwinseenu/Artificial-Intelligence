{
  // ─────────────────────────────────────────────────────────
  //  VS Code settings for local CodeGemma (via Ollama)
  //  Place in: .vscode/settings.json  (project)
  //         or  ~/Library/Application Support/Code/User/settings.json  (global)
  // ─────────────────────────────────────────────────────────

  // ── Continue extension (recommended for code AI) ──────────
  // Install: https://marketplace.visualstudio.com/items?itemName=Continue.continue
  "continue.models": [
    {
      "title": "CodeGemma 7B (Local)",
      "provider": "ollama",
      "model": "codegemma:7b",
      "apiBase": "http://localhost:11434"
    }
  ],
  "continue.tabAutocompleteModel": {
    "title": "CodeGemma Autocomplete",
    "provider": "ollama",
    "model": "codegemma:2b",
    "apiBase": "http://localhost:11434"
  },

  // ── Ollama extension settings ─────────────────────────────
  // Install: https://marketplace.visualstudio.com/items?itemName=ms-vscode.ollama
  "ollama.url": "http://localhost:11434",
  "ollama.model": "codegemma:7b",

  // ── GitHub Copilot alternative — CodeGPT ──────────────────
  // Install: https://marketplace.visualstudio.com/items?itemName=DanielSanMedium.dscodegpt
  "CodeGPT.apiKey": "not-needed-for-local",
  "CodeGPT.model": "codegemma:7b",
  "CodeGPT.ollamaUrl": "http://localhost:11434"
}
